# Railway Template Variables
# Use these values when creating a Railway template

NODE_ENV="production"
PORT=3000 # Same one as in Docker

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres" # Supabase connection string from project settings

BETTER_AUTH_SECRET="${{secret(64)}}" # Auto-generated by Railway
BETTER_AUTH_URL="https://${{RAILWAY_PUBLIC_DOMAIN}}" # Auto-filled by Railway

GOOGLE_CLIENT_ID="not-configured" # From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET="not-configured" # Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google

BASE_URL="https://${{RAILWAY_PUBLIC_DOMAIN}}" # Auto-filled by Railway
TRUSTED_ORIGINS="https://${{RAILWAY_PUBLIC_DOMAIN}}" # Auto-filled by Railway
