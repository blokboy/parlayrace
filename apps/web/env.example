NODE_ENV="development"
PORT=3000 # Same one as in Docker

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres" # Run: bun --filter @starter/backend db:start

BETTER_AUTH_SECRET="dev-secret-change-in-production" # Generate with: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="not-configured" # From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET="not-configured" # Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google

BASE_URL="http://localhost:3000"
TRUSTED_ORIGINS="http://localhost:3000"
